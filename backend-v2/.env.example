# ─────────────────────────────────────────────
#  Copia este archivo como .env y llena los valores reales.
#  NUNCA commitees el .env — ya está en .gitignore.
# ─────────────────────────────────────────────

# Base de datos MySQL
DB_HOST=db
DB_PORT=3306
DB_NAME=pool_services_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_root_password

# JWT
SECRET_KEY=your_secret_key_here_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
